# Copy this file to .env.local and fill in your API key
# Get your key from: https://console.cloud.google.com/
# Required API: Places API (legacy Nearby Search + Place Photos)
#
# GOOGLE_PLACES_API_KEY is SERVER-SIDE ONLY. It is read by the Netlify
# functions (netlify/functions/places-nearby.js, places-photo.js) and is
# picked up locally by `netlify dev`. In production, set it in the Netlify
# site's environment variables.
#
# NEVER prefix this key with REACT_APP_ — Create React App embeds every
# REACT_APP_* variable into the public client JS bundle.

GOOGLE_PLACES_API_KEY=your_api_key_here
